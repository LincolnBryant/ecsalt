{erl_opts, [debug_info]}.
{deps, []}.

{shell, [
    % {config, "config/sys.config"},
    {apps, [ecsalt]}
]}.

{hex, [{doc, ex_doc}]}.
{ex_doc, [
    {source_url, <<"https://github.com/lincolnbryant/ecsalt">>},
    {extras, [<<"README.md">>, <<"LICENSE">>]},
    {main, <<"readme">>}
]}.

{project_plugins, [
    erlfmt,
    rebar3_hex,
    rebar3_hank,
    rebar3_ex_doc
]}.
